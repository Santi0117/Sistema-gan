# ─── Base de datos ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://sistemaganuser:sistemaganpass@localhost:5432/sistemagandb"

# ─── Auth ────────────────────────────────────────────────────────────────────
AUTH_SECRET="change-me-to-a-random-32-char-string"
NEXTAUTH_URL="http://localhost:3000"

# ─── Redis / BullMQ ──────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Hacienda / TRIBU-CR ─────────────────────────────────────────────────────
# PRUEBAS | PRODUCCION
HACIENDA_AMBIENTE="PRUEBAS"

# API pública de Hacienda (contribuyentes, CABYS, tipo de cambio)
HACIENDA_API_URL="https://api.hacienda.go.cr"

# TRIBU-CR (Hacienda Digital) — credenciales del contribuyente
# Estas se almacenan CIFRADAS en la tabla empresa, no aquí
# TRIBU_CR_URL se puede sobrescribir para el ambiente de pruebas
TRIBU_CR_URL="https://tribu-cr.hacienda.go.cr"

# ─── Cifrado en reposo (para credenciales TRIBU-CR y llave .p12) ─────────────
ENCRYPTION_KEY="change-me-to-a-64-char-hex-string"

# ─── Proveedor de sistemas ───────────────────────────────────────────────────
# Cédula jurídica del proveedor del software (requerida en XML 4.4)
PROVEEDOR_SISTEMAS_ID="3-102-XXXXXX"
